+// Swift 6 strict-concurrency patch: `cast(_:appContext:)` is guarded by
+// Thread.isMainThread (throws NonMainThreadException if not on main thread),
+// so we know we are always on the main actor when the view methods are called.
+// `UnsafelySendable` lets us cross the actor boundary inside
+// `MainActor.assumeIsolated` without a Sendable constraint on the wrapped type.
+private struct UnsafelySendable<T>: @unchecked Sendable {
+  let value: T
+}
+
 internal struct DynamicSwiftUIViewType<ViewType: ExpoSwiftUIView>: AnyDynamicType {
   let innerType: ViewType.Type
 
@@ -37,20 +46,25 @@ internal struct DynamicSwiftUIViewType<ViewType: ExpoSwiftUIView>: AnyDynamicTyp
     // Direct match, the virtual view's content type matches exactly.
     // e.g. View(SlotView.self)
     if let view = appContext.findView(withTag: viewTag, ofType: ExpoSwiftUI.SwiftUIVirtualView<ViewType.Props, ViewType>.self) {
-      return view.contentView
+      // contentView is @MainActor-isolated; Thread.isMainThread is already verified above.
+      return MainActor.assumeIsolated { UnsafelySendable(value: view.contentView) }.value
     }
     // For wrapper types
     // e.g. ExpoUIView(SecureFieldView.self)
-    if let provider = appContext.findView(withTag: viewTag, ofType: ExpoSwiftUI.ViewWrapper.self),
-       let innerView = provider.getWrappedView() as? ViewType {
-      return innerView
+    if let provider = appContext.findView(withTag: viewTag, ofType: ExpoSwiftUI.ViewWrapper.self) {
+      // getWrappedView() is @MainActor-isolated; Thread.isMainThread is already verified above.
+      let wrapped = MainActor.assumeIsolated { UnsafelySendable(value: provider.getWrappedView()) }
+      if let innerView = wrapped.value as? ViewType {
+        return innerView
+      }
     }
     // For views using WithHostingView protocol.
     // e.g. View(HostView.self) where HostView conforms to WithHostingView
     guard let view = appContext.findView(withTag: viewTag, ofType: AnyExpoSwiftUIHostingView.self) else {
       throw Exceptions.SwiftUIViewNotFound((tag: viewTag, type: innerType.self))
     }
-    return view.getContentView()
+    // getContentView() is @MainActor-isolated; Thread.isMainThread is already verified above.
+    return MainActor.assumeIsolated { UnsafelySendable(value: view.getContentView()) }.value
   }
 
   var description: String {
