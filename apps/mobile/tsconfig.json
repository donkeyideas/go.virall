{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@govirall/core": ["../../packages/core/src"],
      "@govirall/api-types": ["../../packages/api-types/src"],
      "@govirall/design-tokens": ["../../packages/design-tokens/src"]
